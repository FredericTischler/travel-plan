# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.3.2
# ----------------------------------------------------------------------------

# If JAVA_HOME is not set, try to infer it.
if [ -z "$JAVA_HOME" ]; then
  if [ -x "/usr/libexec/java_home" ]; then
    JAVA_HOME="$(/usr/libexec/java_home)"
  elif [ -d "/usr/lib/jvm/default-java" ]; then
    JAVA_HOME="/usr/lib/jvm/default-java"
  fi
fi

JAVA_CMD="${JAVA_HOME}/bin/java"
if [ -z "$JAVA_HOME" ] || [ ! -x "$JAVA_CMD" ]; then
  JAVA_CMD="java"
fi

# Locate the wrapper properties file.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_PROPERTIES="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.properties"

# Extract distributionUrl.
DISTRIBUTION_URL=$(grep "^distributionUrl" "$WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')

# Determine the local Maven installation directory.
M2_HOME="${M2_HOME:-$HOME/.m2}"
MAVEN_HOME="$M2_HOME/wrapper/dists/$(basename "$DISTRIBUTION_URL" .zip)"

if [ ! -d "$MAVEN_HOME" ]; then
  mkdir -p "$MAVEN_HOME"
  echo "Downloading Maven from $DISTRIBUTION_URL ..."
  TMPFILE=$(mktemp /tmp/maven-dist.XXXXXX.zip)
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$TMPFILE"
  elif command -v wget > /dev/null 2>&1; then
    wget -q "$DISTRIBUTION_URL" -O "$TMPFILE"
  else
    echo "ERROR: Neither curl nor wget available. Cannot download Maven." >&2
    exit 1
  fi
  unzip -q "$TMPFILE" -d "$MAVEN_HOME"
  rm "$TMPFILE"
fi

# Find the mvn binary inside the extracted directory.
MVN_CMD=$(find "$MAVEN_HOME" -name "mvn" -type f | head -1)
if [ -z "$MVN_CMD" ]; then
  echo "ERROR: Could not locate mvn binary under $MAVEN_HOME" >&2
  exit 1
fi

exec "$MVN_CMD" "$@"