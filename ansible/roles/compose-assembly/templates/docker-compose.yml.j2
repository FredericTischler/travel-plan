#jinja2: trim_blocks: True, lstrip_blocks: True
# {{ ansible_managed }}
# Point d'entree Compose pour Travel-Plan.
# Assemble les fragments rendus par les roles Ansible postgres / vault / neo4j.
# Réseaux créés par Ansible (community.docker.docker_network) — externes à Compose.
#
# PROFILS (cf. docs/architecture-decisions.md §4) :
#   core : postgres + vault (dev quotidien, ~350 Mo, laisse place à IDE + navigateur)
#   full : postgres + vault + neo4j (intégration + démo, IDE fermé)
#
# USAGE :
#   docker compose --profile core up -d    # dev quotidien
#   docker compose --profile full up -d    # stack complète
#   docker compose --profile full down     # nettoyage

include:
  - path: {{ assembly_postgres_fragment }}
  - path: {{ assembly_vault_fragment }}
  - path: {{ assembly_neo4j_fragment }}
  # traefik : la GATEWAY, rôle Ansible stable (fragment rendu sous
  # {{ assembly_compose_dir }}/traefik/). Inclus SANS flag conditionnel — contrairement
  # à identity, ce n'est pas un fragment statique optionnel du dépôt à chemin variable.
  - path: {{ assembly_traefik_fragment }}
{% if assembly_identity_enabled %}
  # identity-service : fragment STATIQUE du dépôt (build depuis les sources),
  # référencé par CHEMIN ABSOLU (co-localisé avec Dockerfile + src/), pas rendu
  # sous {{ assembly_compose_dir }}. Activé via assembly_identity_enabled=true.
  - path: {{ assembly_identity_fragment }}
{% endif %}

services:
  # Profils appliqués par merge sur les services inclus (Compose spec : les attributs
  # du fichier top-level FUSIONNENT avec les services inclus de même nom).
  postgres:
    profiles: [core, full]

  vault:
    profiles: [core, full]

  # Neo4j = poste RAM le plus lourd (~600 Mo–1 Go, cf. §4).
  # Exclu du profil core pour libérer ~1 Go en dev quotidien.
  neo4j:
    profiles: [full]

  # traefik : profil [core, full] — présent MÊME en core.
  # Justification : Traefik est le SEUL point d'entrée du système (le seul port
  # publié, 443). Sans lui, aucun service routé n'est joignable, même en dev
  # quotidien. Il doit donc rester dans "core" ; l'exclure rendrait la stack core
  # inaccessible de l'extérieur. Profils appliqués par merge sur le service inclus
  # (même mécanisme que postgres/vault ci-dessus).
  traefik:
    profiles: [core, full]
{% if assembly_identity_enabled %}

  # identity-service : profil [full] uniquement pour l'instant (pas core).
  # Pas encore de raison de le charger dans le dev quotidien ; à revalider si le
  # service devient utilisé au quotidien. Profils appliqués par merge sur le
  # service inclus (même mécanisme que postgres/vault/neo4j ci-dessus).
  identity-service:
    profiles: [full]
{% endif %}